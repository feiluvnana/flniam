{
  "name": "flniam",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "nest build",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "migration:create": "mikro-orm migration:create --config src/config/orm.config.ts",
    "migration:up": "mikro-orm migration:up --config src/config/orm.config.ts",
    "migration:down": "mikro-orm migration:down --config src/config/orm.config.ts"
  },
  "dependencies": {
    "@mikro-orm/core": "^6.6.6",
    "@mikro-orm/migrations": "^6.6.6",
    "@mikro-orm/mysql": "^6.6.6",
    "@mikro-orm/nestjs": "^6.1.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/mapped-types": "*",
    "@nestjs/platform-express": "^11.0.1",
    "nestjs-zod": "^5.1.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@mikro-orm/cli": "^6.6.6",
    "@nestjs/cli": "^11.0.0",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.10.7",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.7",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "prettier": "^3.4.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}

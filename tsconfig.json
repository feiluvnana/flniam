{
  "compilerOptions": {
    "outDir": "./dist",
    "target": "ES2023",
    "module": "commonjs",
    "incremental": true,
    "skipLibCheck": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "noImplicitAny": false,
    "strictNullChecks": true
  }
}